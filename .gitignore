# Root .gitignore for Kodex Project

# Dependency directories
node_modules/
**/node_modules/

# Build outputs
dist/
build/
.vercel/

# Environment files
.env*
!.env.example

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*

# OS/Editor files
.DS_Store
Thumbs.db
.vscode/

# Database
*.db
*.sqlite

# Local scratch files
scratch/
kodex-main/scratch/
test.txt
kodex-main/cookies.txt

